{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "control-center-width": 300,
  "control-center-height": 500,
  "control-center-margin-top": 5,
  "control-center-margin-bottom": 5,
  "control-center-margin-right": 5,
  "control-center-margin-left": 5,
  "notification-window-width": 280,
  "transition-time": 150,
  "hide-on-clear": true,
  "hide-on-action": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "app-icon-visibility": "when-available",
  "timeout": 4,
  "timeout-low": 2,
  "timeout-critical": 0,
  "fit-to-screen": false,
  "widgets": [
    "title",
    "dnd",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 64,
      "image-radius": 4
    }
  }
}
